{
  "name": "sweet-spicy-monorepo",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "pnpm run test:unit && pnpm run test:web",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:web": "pnpm --filter web exec vitest run",
    "dev:web": "turbo run dev --filter=web",
    "dev:api": "turbo run dev --filter=api"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "eslint": "^10.0.0",
    "globals": "^16.0.0",
    "turbo": "^2.3.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "19",
        "react-dom": "19",
        "eslint": "^9.0.0 || ^10.0.0"
      }
    }
  }
}
