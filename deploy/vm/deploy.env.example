# Copy to /opt/sweet-spicy/deploy.env (never commit real deploy.env with secrets from GHCR if you use PAT there).
#
# Usage on the server:
#   set -a && source /opt/sweet-spicy/deploy.env && set +a
#   docker compose -f /opt/sweet-spicy/docker-compose.prod.yml pull
#   docker compose -f /opt/sweet-spicy/docker-compose.prod.yml up -d postgres redis
#   … (see deploy/vm/README.md or scripts/deploy/deploy-vm.sh)
#
# Tags from Actions: each push tags :main, :latest, and :<full-commit-sha>.
# Prefer the same tag for web + api (e.g. main or a specific sha).

WEB_IMAGE=ghcr.io/longuit2002-blip/spicy-sweet-game-web:main
API_IMAGE=ghcr.io/longuit2002-blip/spicy-sweet-game-api:main
