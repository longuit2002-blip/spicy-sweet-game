# Copy to /opt/sweet-spicy/.env on the EC2 host (never commit real secrets).
# Replace example.com (or use http://YOUR_EC2_PUBLIC_IP for a first HTTP-only deploy).

# --- Injected by compose / deploy (not always needed inside .env if exported in shell) ---
# WEB_IMAGE=ghcr.io/your-org/sweet-spicy-web:main
# API_IMAGE=ghcr.io/your-org/sweet-spicy-api:main

# --- Postgres (same VM; docker-compose.prod.yml `postgres` service) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=sweet_spicy

# --- API (Nest) runtime ---
# Listen port is set in docker-compose.prod.yml (api: PORT=8000). Do not set PORT here — it is
# loaded for *all* services and would make Next.js bind to 8000 while the proxy expects 3000.

# Hostname `postgres` is the Compose service name (not localhost).
# Password must match POSTGRES_PASSWORD above.
DATABASE_URL=postgresql://postgres:change-me-strong-db-password@postgres:5432/sweet_spicy
JWT_SECRET=change-me-long-random-string
CLIENT_URL=https://sweetspicy.example.com
WEBRTC_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302,stun:stun2.l.google.com:19302
WEBRTC_TURN_URLS=turn:turn.sweetspicy.example.com:3478?transport=udp,turn:turn.sweetspicy.example.com:3478?transport=tcp
WEBRTC_TURN_USERNAME=change-me-turn-username
WEBRTC_TURN_CREDENTIAL=change-me-turn-password

# --- Web (Next) runtime — must match what was baked into the web image at build time ---
# Rebuild the web image if you change these public URLs.
NEXT_PUBLIC_API_URL=https://sweetspicy.example.com/api
NEXT_PUBLIC_SOCKET_URL=https://sweetspicy.example.com
