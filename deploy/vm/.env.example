# Copy to /opt/sweet-spicy/.env on the EC2 host (never commit real secrets).
# Replace example.com with your public domain or Elastic IP URL.

# --- Injected by compose / deploy (not always needed inside .env if exported in shell) ---
# WEB_IMAGE=ghcr.io/your-org/sweet-spicy-web:main
# API_IMAGE=ghcr.io/your-org/sweet-spicy-api:main

# --- API (Nest) runtime ---
PORT=8000
DATABASE_URL=postgresql://user:password@your-db-host:5432/sweet_spicy
JWT_SECRET=change-me-long-random-string
CLIENT_URL=https://sweetspicy.example.com

# --- Web (Next) runtime — must match what was baked into the web image at build time ---
# Rebuild the web image if you change these public URLs.
NEXT_PUBLIC_API_URL=https://sweetspicy.example.com/api
NEXT_PUBLIC_SOCKET_URL=https://sweetspicy.example.com
