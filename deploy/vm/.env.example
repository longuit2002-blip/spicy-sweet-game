# Copy to /opt/sweet-spicy/.env on the VM (never commit real secrets).
# Replace example.com (or use http://YOUR_EC2_PUBLIC_IP for first HTTP-only deploy).

# Optional image tags are usually provided via deploy.env (not required here):
# WEB_IMAGE=ghcr.io/your-org/sweet-spicy-web:main
# API_IMAGE=ghcr.io/your-org/sweet-spicy-api:main

# --- Postgres (same VM; docker-compose `postgres` service) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=sweet_spicy

# --- API (Nest) runtime ---
# Do not set PORT here; compose sets web/api PORT separately.
DATABASE_URL=postgresql://postgres:change-me-strong-db-password@postgres:5432/sweet_spicy
JWT_SECRET=change-me-long-random-string
CLIENT_URL=https://sweetspicy.example.com

# Redis for Socket.IO adapter + active room/session state.
# If Redis runs as docker service named `redis`, keep value below.
# If Redis runs on host service, use a host-reachable address from containers.
REDIS_URL=redis://redis:6379

# LiveKit Cloud Free
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# --- Web (Next) runtime ---
# These NEXT_PUBLIC_* values are compile-time values in the web image.
# Rebuild web image if they change.
NEXT_PUBLIC_API_URL=https://sweetspicy.example.com/api
NEXT_PUBLIC_SOCKET_URL=https://sweetspicy.example.com
NEXT_PUBLIC_LIVEKIT_ENABLED=true
